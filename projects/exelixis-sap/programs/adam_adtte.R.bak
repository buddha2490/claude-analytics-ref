# =============================================================================
# Program: cohort/adam_adtte.R
# Study: NPM-008 / Exelixis XB010-100
# Dataset: ADTTE — Time to Event Analysis Dataset
# Author: r-clinical-programmer agent
# Date: 2026-03-27
#
# Source Domains:
#   - RS (XPT): USUBJID, RSSTRESC, RSDTC, RSTESTCD, VISIT — progression assessments
#   - DM (XPT): USUBJID, DTHDTC, DTHFL, STUDYID, RFENDTC — death date and identifiers
#   - ADSL (XPT): USUBJID, TRTSDT, RFENDTC — treatment start date and study end
#   - ADRS (XPT): USUBJID, PARAMCD, AVALC, ADT — BOR records for DOR eligibility
#
# CDISC References:
#   - ADaM-IG v1.3 Time-to-Event Analysis Dataset structure
#   - SAP Section 8: PFS, OS, DOR definitions and censoring rules
#   - Open-questions-cdisc.md R3 (confirmed response requirement for DOR)
#   - Open-questions-cdisc.md R4 (month conversion: days / 30.4375)
#
# Dependencies:
#   - ADSL (cohort/output-data/adsl.xpt) — required for TRTSDT, RFENDTC
#   - ADRS (cohort/output-data/adrs.xpt) — required for DOR responder identification
#
# Parameters:
#   - PFS: Progression-Free Survival (event = progression or death)
#   - OS: Overall Survival (event = death)
#   - DOR: Duration of Response (event = progression or death after response)
#
# REVISIT: Month conversion factor (days / 30.4375) per SAP.
#          See artifacts/NPM-008/Open-questions-cdisc.md R4
# REVISIT: Confirmed response requirement (≥28-day interval) for DOR.
#          See artifacts/NPM-008/Open-questions-cdisc.md R3
# =============================================================================

# --- Load packages -----------------------------------------------------------
library(haven)
library(dplyr)
library(tidyr)
library(stringr)
library(lubridate)
library(xportr)

# --- Read source data --------------------------------------------------------
dm <- haven::read_xpt("cohort/output-data/dm.xpt")
rs <- haven::read_xpt("cohort/output-data/rs.xpt")
adsl <- haven::read_xpt("cohort/output-data/adsl.xpt")
adrs <- haven::read_xpt("cohort/output-data/adrs.xpt")

# --- Exploration (remove after validation) -----------------------------------
# Check RS structure
message("RS domain structure:")
message("  Rows: ", nrow(rs))
message("  Subjects: ", n_distinct(rs$USUBJID))
message("  RSTESTCD values: ", paste(unique(rs$RSTESTCD), collapse = ", "))
message("  RSSTRESC values: ", paste(unique(rs$RSSTRESC), collapse = ", "))

# Check DM death data
message("\nDM death data:")
message("  Subjects with DTHFL='Y': ", sum(dm$DTHFL == "Y", na.rm = TRUE))
message("  Subjects with non-missing DTHDTC: ", sum(!is.na(dm$DTHDTC)))

# Check ADRS BOR records
message("\nADRS BOR records:")
adrs_bor <- adrs %>% filter(PARAMCD == "BOR")
message("  BOR records: ", nrow(adrs_bor))
message("  AVALC values in BOR: ", paste(unique(adrs_bor$AVALC), collapse = ", "))
message("  Responders (CR/PR): ", sum(adrs_bor$AVALC %in% c("CR", "PR"), na.rm = TRUE))

# Check ADSL TRTSDT completeness
message("\nADSL treatment dates:")
message("  Subjects: ", nrow(adsl))
message("  Missing TRTSDT: ", sum(is.na(adsl$TRTSDT)))
message("  Missing RFENDTC: ", sum(is.na(adsl$RFENDTC)))

# --- Derive progression date from RS -----------------------------------------
# Filter to RECIST overall response assessments (RSTESTCD = 'RECIST')
# NOTE: RSTESTCD = 'CLINRES' are clinician-stated BOR and not used for event derivation
rs_recist <- rs %>%
  filter(RSTESTCD == "RECIST") %>%
  mutate(RSDTC_DATE = as.Date(RSDTC))

# Identify first progression date per subject
progression <- rs_recist %>%
  filter(RSSTRESC == "PD") %>%
  group_by(USUBJID) %>%
  summarise(
    PROGDT = min(RSDTC_DATE, na.rm = TRUE),
    .groups = "drop"
  )

# --- Derive death date from DM -----------------------------------------------
death <- dm %>%
  filter(DTHFL == "Y" & !is.na(DTHDTC)) %>%
  mutate(DTHDT = as.Date(DTHDTC)) %>%
  select(USUBJID, DTHDT)

# --- Derive last disease assessment date from RS -----------------------------
last_assessment <- rs_recist %>%
  group_by(USUBJID) %>%
  summarise(
    LASTASDT = max(RSDTC_DATE, na.rm = TRUE),
    .groups = "drop"
  )

# --- Identify responders from ADRS BOR ---------------------------------------
# REVISIT: Confirmed response requirement per SAP Section (≥28-day interval).
#          See artifacts/NPM-008/Open-questions-cdisc.md R3
responders <- adrs %>%
  filter(PARAMCD == "BOR" & AVALC %in% c("CR", "PR")) %>%
  select(USUBJID, BOR = AVALC, BORDT = ADT)

# For DOR, need first confirmed response date from visit-level ADRS records
# (BOR record doesn't have the date of first response)
first_response <- adrs %>%
  filter(PARAMCD == "OVRLRESP" & AVALC %in% c("CR", "PR")) %>%
  group_by(USUBJID) %>%
  summarise(
    FIRSTRESPDT = min(ADT, na.rm = TRUE),
    .groups = "drop"
  )

# --- Merge all event data with ADSL ------------------------------------------
adsl_tte <- adsl %>%
  select(USUBJID, STUDYID, TRTSDT, TRTEDT, RFENDTC) %>%
  mutate(
    RFENDDT = as.numeric(as.Date(RFENDTC)),
    TRTSDTN = TRTSDT  # Already numeric in ADSL
  ) %>%
  left_join(progression, by = "USUBJID") %>%
  left_join(death, by = "USUBJID") %>%
  left_join(last_assessment, by = "USUBJID") %>%
  left_join(responders, by = "USUBJID") %>%
  left_join(first_response, by = "USUBJID") %>%
  mutate(
    PROGDTN = as.numeric(PROGDT),
    DTHDTN = as.numeric(DTHDT),
    LASTASN = as.numeric(LASTASDT),
    FIRSTRESP = as.numeric(FIRSTRESPDT)
  )

# --- Derive PFS parameter ----------------------------------------------------
adtte_pfs <- adsl_tte %>%
  mutate(
    PARAMCD = "PFS",
    PARAM = "Progression-Free Survival (Months)",
    STARTDT = TRTSDTN,

    # Event logic: progression or death, whichever comes first
    EVENT_PROG = !is.na(PROGDTN),
    EVENT_DTH = !is.na(DTHDTN),

    # Determine event date and type
    EVNTDT = case_when(
      EVENT_PROG & EVENT_DTH ~ pmin(PROGDTN, DTHDTN, na.rm = TRUE),
      EVENT_PROG ~ PROGDTN,
      EVENT_DTH ~ DTHDTN,
      TRUE ~ NA_real_
    ),

    EVNTTYPE = case_when(
      !is.na(EVNTDT) & EVNTDT == PROGDTN ~ "PROGRESSIVE DISEASE",
      !is.na(EVNTDT) & EVNTDT == DTHDTN ~ "DEATH",
      TRUE ~ NA_character_
    ),

    # Censoring: use last disease assessment or RFENDTC if no assessment
    CNSRDT = case_when(
      is.na(EVNTDT) & !is.na(LASTASN) ~ LASTASN,
      is.na(EVNTDT) & !is.na(RFENDDT) ~ RFENDDT,
      TRUE ~ NA_real_
    ),

    CNSRTYPE = case_when(
      !is.na(CNSRDT) & CNSRDT == LASTASN ~ "LAST DISEASE ASSESSMENT",
      !is.na(CNSRDT) & CNSRDT == RFENDDT ~ "STUDY END DATE",
      TRUE ~ NA_character_
    ),

    # Final ADT and CNSR
    ADT = coalesce(EVNTDT, CNSRDT),
    CNSR = ifelse(is.na(EVNTDT), 1, 0),

    # AVAL: time from STARTDT to ADT in months
    # REVISIT: Month conversion factor (days / 30.4375) per SAP
    #          See artifacts/NPM-008/Open-questions-cdisc.md R4
    AVAL = (ADT - STARTDT + 1) / 30.4375,

    EVNTDESC = EVNTTYPE,
    CNSDTDSC = CNSRTYPE
  ) %>%
  select(USUBJID, STUDYID, PARAMCD, PARAM, STARTDT, ADT, AVAL, CNSR,
         EVNTDESC, CNSDTDSC)

# --- Derive OS parameter -----------------------------------------------------
adtte_os <- adsl_tte %>%
  mutate(
    PARAMCD = "OS",
    PARAM = "Overall Survival (Months)",
    STARTDT = TRTSDTN,

    # Event logic: death only
    EVENT_DTH = !is.na(DTHDTN),

    # Determine event or censoring
    EVNTDT = if_else(EVENT_DTH, DTHDTN, NA_real_),
    EVNTTYPE = if_else(EVENT_DTH, "DEATH", NA_character_),

    # Censoring: RFENDTC (last known alive)
    CNSRDT = if_else(is.na(EVNTDT), RFENDDT, NA_real_),
    CNSRTYPE = if_else(!is.na(CNSRDT), "LAST KNOWN ALIVE", NA_character_),

    # Final ADT and CNSR
    ADT = coalesce(EVNTDT, CNSRDT),
    CNSR = ifelse(is.na(EVNTDT), 1, 0),

    # AVAL: time from STARTDT to ADT in months
    # REVISIT: Month conversion factor (days / 30.4375) per SAP
    #          See artifacts/NPM-008/Open-questions-cdisc.md R4
    AVAL = (ADT - STARTDT + 1) / 30.4375,

    EVNTDESC = EVNTTYPE,
    CNSDTDSC = CNSRTYPE
  ) %>%
  select(USUBJID, STUDYID, PARAMCD, PARAM, STARTDT, ADT, AVAL, CNSR,
         EVNTDESC, CNSDTDSC)

# --- Derive DOR parameter (responders only) ----------------------------------
# DOR is only calculated for subjects who achieved CR or PR
adtte_dor <- adsl_tte %>%
  filter(!is.na(BOR) & BOR %in% c("CR", "PR")) %>%
  mutate(
    PARAMCD = "DOR",
    PARAM = "Duration of Response (Months)",
    STARTDT = FIRSTRESP,

    # Event logic: progression or death after response
    EVENT_PROG = !is.na(PROGDTN) & PROGDTN >= FIRSTRESP,
    EVENT_DTH = !is.na(DTHDTN) & DTHDTN >= FIRSTRESP,

    # Determine event date and type
    EVNTDT = case_when(
      EVENT_PROG & EVENT_DTH ~ pmin(PROGDTN, DTHDTN, na.rm = TRUE),
      EVENT_PROG ~ PROGDTN,
      EVENT_DTH ~ DTHDTN,
      TRUE ~ NA_real_
    ),

    EVNTTYPE = case_when(
      !is.na(EVNTDT) & EVNTDT == PROGDTN ~ "PROGRESSIVE DISEASE",
      !is.na(EVNTDT) & EVNTDT == DTHDTN ~ "DEATH",
      TRUE ~ NA_character_
    ),

    # Censoring: use last disease assessment after response
    CNSRDT = case_when(
      is.na(EVNTDT) & !is.na(LASTASN) & LASTASN >= FIRSTRESP ~ LASTASN,
      is.na(EVNTDT) & !is.na(RFENDDT) ~ RFENDDT,
      TRUE ~ NA_real_
    ),

    CNSRTYPE = case_when(
      !is.na(CNSRDT) & CNSRDT == LASTASN ~ "LAST DISEASE ASSESSMENT",
      !is.na(CNSRDT) & CNSRDT == RFENDDT ~ "STUDY END DATE",
      TRUE ~ NA_character_
    ),

    # Final ADT and CNSR
    ADT = coalesce(EVNTDT, CNSRDT),
    CNSR = ifelse(is.na(EVNTDT), 1, 0),

    # AVAL: time from first response to ADT in months
    # REVISIT: Month conversion factor (days / 30.4375) per SAP
    #          See artifacts/NPM-008/Open-questions-cdisc.md R4
    AVAL = (ADT - STARTDT + 1) / 30.4375,

    EVNTDESC = EVNTTYPE,
    CNSDTDSC = CNSRTYPE
  ) %>%
  select(USUBJID, STUDYID, PARAMCD, PARAM, STARTDT, ADT, AVAL, CNSR,
         EVNTDESC, CNSDTDSC)

# --- Combine all parameters --------------------------------------------------
adtte <- bind_rows(adtte_pfs, adtte_os, adtte_dor) %>%
  arrange(USUBJID, PARAMCD)

# --- Apply variable labels and types -----------------------------------------
adtte_meta <- tibble::tibble(
  variable = c("STUDYID", "USUBJID", "PARAMCD", "PARAM", "STARTDT",
               "ADT", "AVAL", "CNSR", "EVNTDESC", "CNSDTDSC"),
  label = c(
    "Study Identifier",
    "Unique Subject Identifier",
    "Parameter Code",
    "Parameter Description",
    "Start Date for TTE (Numeric SAS Date)",
    "Analysis Date (Event or Censor, Numeric SAS Date)",
    "Analysis Value (Time in Months)",
    "Censoring Indicator (0=Event, 1=Censored)",
    "Event Description",
    "Censoring Date Description"
  ),
  type = c("character", "character", "character", "character", "numeric",
           "numeric", "numeric", "numeric", "character", "character")
)

adtte <- adtte %>%
  xportr::xportr_label(metadata = adtte_meta, domain = "ADTTE") %>%
  xportr::xportr_type(metadata = adtte_meta, domain = "ADTTE")

# --- Validation checks -------------------------------------------------------
message("\n=== ADTTE Validation ===")
message("Total rows: ", nrow(adtte))
message("Total subjects: ", n_distinct(adtte$USUBJID))

# Parameter counts
message("\nParameter counts:")
adtte %>%
  count(PARAMCD) %>%
  print()

# Event vs censored by parameter
message("\nEvent vs censored by parameter:")
adtte %>%
  count(PARAMCD, CNSR) %>%
  mutate(CNSR_LABEL = ifelse(CNSR == 0, "Event", "Censored")) %>%
  select(-CNSR) %>%
  print()

# Check for missing key variables
message("\nMissing value counts:")
sapply(adtte, function(x) sum(is.na(x))) %>% print()

# Check for negative AVAL
message("\nNegative AVAL values: ", sum(adtte$AVAL < 0, na.rm = TRUE))
if (any(adtte$AVAL < 0, na.rm = TRUE)) {
  message("WARNING: Negative AVAL detected!")
  adtte %>% filter(AVAL < 0) %>% print()
}

# Check USUBJID all in ADSL
message("\nAll subjects in ADSL: ", all(adtte$USUBJID %in% adsl$USUBJID))

# Distribution of AVAL by parameter
message("\nAVAL distribution by parameter:")
adtte %>%
  group_by(PARAMCD) %>%
  summarise(
    N = n(),
    Mean = mean(AVAL, na.rm = TRUE),
    Median = median(AVAL, na.rm = TRUE),
    Min = min(AVAL, na.rm = TRUE),
    Max = max(AVAL, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  print()

# --- Save dataset ------------------------------------------------------------
saveRDS(adtte, "cohort/output-data/adtte.rds")
haven::write_xpt(adtte, "cohort/output-data/adtte.xpt")
message("\nDataset saved to: cohort/output-data/adtte.xpt")
message("Program complete.")
